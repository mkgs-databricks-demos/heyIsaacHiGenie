# Hey Isaac / Hi Genie — local development
# Copy to server/.env and fill in values.
# Run against the deployed Lakebase (deploy infra bundle first).

# Databricks workspace (for local dev auth)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Lakebase connection — auto-injected in production; set manually for local dev
# Get values from: databricks postgres list-endpoints projects/<id>/branches/production
# PGHOST=<lakebase-endpoint-host>
# PGDATABASE=<database-name>
# PGSSLMODE=require
# LAKEBASE_ENDPOINT=projects/<id>/branches/production/databases/<db-id>

# Persona token HMAC signing key — must match the value in the secret scope
# Generate: openssl rand -base64 64
HI_GENIE_JWT_SIGNING_KEY=

# Persona token configuration
HI_GENIE_PERSONA_ISSUER=        # Stable app URL, e.g. https://your-app.databricksapps.com/token/persona
HI_GENIE_PERSONA_AUDIENCE=mcp  # Audience claim verified on every persona token

# Dynamic Client Registration (spike guard)
HI_GENIE_DCR_SHARED_SECRET=    # Shared secret for POST /register — generate: openssl rand -base64 32

# GitHub OAuth App — Phase 5, not needed for spike
# HI_GENIE_GITHUB_CLIENT_ID=
# HI_GENIE_GITHUB_CLIENT_SECRET=
